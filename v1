<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Clavia · Asesoría Fiscal para Autónomos</title>
<meta name="description" content="Asesoría fiscal y contable online para autónomos y freelances. Precio fijo desde 39€/mes. Primer mes gratis.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400;1,9..144,500&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>

/* ═══════════════════════════════════════════════════════════
   CLAVIA v8 — EDITORIAL FINTECH
   Inspiración: Wise · Qonto · Pennylane · Linear
   
   Paleta:
   Fondo principal:  #faf8f3  crema cálida
   Verde profundo:   #0b2218  bosque (secciones, hero orb)
   Verde medio:      #0e6644  para textos sobre claro
   Verde acento:     #00c07a  sage vivo
   Coral/acción:     #e8532a  todos los CTAs
   Coral claro:      #f97316  para hovers
   Negro cálido:     #181410  texto principal
   Gris cálido:      #6b6560  texto secundario
   ═══════════════════════════════════════════════════════════ */

:root {
  --cream:    #faf8f3;
  --cream2:   #f0ede5;
  --cream3:   #e4e0d8;
  --forest:   #0b2218;
  --forest2:  #0e6644;
  --sage:     #00c07a;
  --sage-lo:  rgba(0,192,122,.12);
  --sage-bd:  rgba(0,192,122,.28);
  --coral:    #e8532a;
  --coral2:   #f06030;
  --coral-lo: rgba(232,83,42,.1);
  --ink:      #181410;
  --ink2:     #3a3530;
  --grey:     #6b6560;
  --grey2:    #9a9590;
  --line:     rgba(24,20,16,.1);
  --line-inv: rgba(255,255,255,.12);

  --serif: 'Fraunces', Georgia, serif;
  --sans:  'Plus Jakarta Sans', system-ui, sans-serif;
  --mono:  'JetBrains Mono', monospace;

  --r:  8px;
  --rr: 16px;
  --rrr: 24px;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body {
  font-family: var(--sans);
  background: var(--cream);
  color: var(--ink);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}
a { text-decoration:none; color:inherit; }
button { cursor:pointer; font-family:inherit; }

/* Grain texture overlay */
body::before {
  content:''; position:fixed; inset:0; z-index:1000; pointer-events:none;
  opacity:.025;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  background-repeat: repeat;
  background-size: 180px;
}

.wrap { max-width:1100px; margin:0 auto; padding:0 40px; }

@keyframes fadeUp   { from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)} }
@keyframes fadeIn   { from{opacity:0}to{opacity:1} }
@keyframes roll     { from{transform:translateX(0)}to{transform:translateX(-50%)} }
@keyframes float    { 0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)} }
@keyframes orb-spin { from{transform:rotate(0deg)}to{transform:rotate(360deg)} }

.rv { opacity:0; transform:translateY(20px); transition:opacity .7s ease,transform .7s ease; }
.rv.on { opacity:1; transform:translateY(0); }

/* ══════════════════════════════════════════════════════ NAV */
nav {
  position:fixed; top:0; left:0; right:0; z-index:500;
  padding:18px 0;
  transition:all .3s;
  border-bottom:1px solid transparent;
}
nav.stuck {
  background:rgba(250,248,243,.92);
  backdrop-filter:blur(20px);
  border-bottom-color:var(--line);
}
.nav-row { display:flex; align-items:center; justify-content:space-between; }

/* Logo */
.logo { display:flex; align-items:center; gap:3px; }
.logo-text { font-family:var(--serif); font-size:22px; font-weight:500; color:var(--ink); letter-spacing:-.3px; }
.logo-dot  { width:7px; height:7px; background:var(--sage); border-radius:50%; margin-bottom:12px; flex-shrink:0; }

.nav-links { display:flex; align-items:center; gap:32px; list-style:none; }
.nav-links a { font-size:14px; font-weight:500; color:var(--ink2); transition:color .2s; }
.nav-links a:hover { color:var(--ink); }
.nav-cta {
  background:var(--coral); color:#fff;
  padding:10px 22px; border-radius:100px;
  font-size:14px; font-weight:700;
  transition:background .2s, transform .2s;
}
.nav-cta:hover { background:var(--coral2); transform:translateY(-1px); }

.ham { display:none; flex-direction:column; gap:5px; cursor:pointer; }
.ham span { display:block; width:22px; height:1.5px; background:var(--ink); border-radius:2px; }
.mob {
  display:none; position:fixed; inset:0; background:var(--cream); z-index:499;
  flex-direction:column; align-items:center; justify-content:center; gap:28px;
}
.mob.open { display:flex; }
.mob a { font-family:var(--serif); font-size:36px; color:var(--ink); }
.mob-x { position:absolute; top:22px; right:28px; font-size:28px; color:var(--grey); cursor:pointer; }

/* ══════════════════════════════════════════════════════ HERO */
.hero {
  min-height:100vh; display:flex; align-items:center;
  padding:140px 0 80px; position:relative; overflow:hidden;
  background:var(--cream);
}

/* Orb decorativo */
.orb {
  position:absolute; top:-120px; right:-200px;
  width:700px; height:700px; border-radius:50%;
  background:conic-gradient(from 0deg, #0b2218, #0e6644, #00c07a, #0b2218);
  opacity:.06; pointer-events:none;
  animation:orb-spin 30s linear infinite;
}
.orb2 {
  position:absolute; bottom:-80px; left:-100px;
  width:400px; height:400px; border-radius:50%;
  background:radial-gradient(circle, var(--coral) 0%, transparent 70%);
  opacity:.05; pointer-events:none;
}

.hero-layout {
  display:grid;
  grid-template-columns:1.1fr 1fr;
  gap:64px; align-items:center;
}

/* Label eyebrow */
.eyebrow {
  display:inline-flex; align-items:center; gap:8px;
  font-size:11px; font-weight:700; letter-spacing:2.5px;
  text-transform:uppercase; color:var(--sage);
  margin-bottom:20px;
}
.eyebrow::before { content:''; width:20px; height:1.5px; background:var(--sage); }

.hero h1 {
  font-family:var(--serif);
  font-size:clamp(46px,5.8vw,80px);
  font-weight:400; line-height:1.02;
  letter-spacing:-.5px; color:var(--ink);
  margin-bottom:24px;
}
.hero h1 em {
  font-style:italic; color:var(--forest2);
}
.hero h1 .hi {
  position:relative; display:inline-block;
}
.hero h1 .hi::after {
  content:''; position:absolute; bottom:4px; left:0; right:0; height:3px;
  background:var(--coral); border-radius:2px;
}

.hero-p {
  font-size:17px; color:var(--grey); line-height:1.7;
  font-weight:400; max-width:460px; margin-bottom:36px;
}

.hero-btns { display:flex; align-items:center; gap:16px; flex-wrap:wrap; margin-bottom:40px; }

.btn-coral {
  background:var(--coral); color:#fff;
  padding:14px 30px; border-radius:100px;
  font-size:15px; font-weight:700; border:none;
  display:inline-flex; align-items:center; gap:8px;
  transition:background .2s, transform .2s, box-shadow .2s;
  box-shadow:0 4px 20px rgba(232,83,42,.3);
}
.btn-coral:hover {
  background:var(--coral2); transform:translateY(-2px);
  box-shadow:0 8px 28px rgba(232,83,42,.38);
}

.btn-outline {
  background:transparent; color:var(--ink2);
  padding:14px 24px; border-radius:100px;
  font-size:15px; font-weight:600;
  border:1.5px solid var(--line);
  display:inline-flex; align-items:center; gap:6px;
  transition:all .2s;
}
.btn-outline:hover { border-color:var(--ink); color:var(--ink); gap:10px; }

/* Trust row */
.trust { display:flex; flex-wrap:wrap; gap:20px; }
.trust-i { display:flex; align-items:center; gap:7px; font-size:13px; color:var(--grey2); }
.trust-i .dot { width:5px; height:5px; border-radius:50%; background:var(--sage); flex-shrink:0; }

/* Hero card — verde profundo */
.hero-card {
  background:var(--forest);
  border-radius:var(--rrr);
  padding:36px; position:relative;
  overflow:hidden;
  animation:fadeUp .9s .2s both;
  box-shadow:0 32px 72px rgba(30,58,34,.25);
}
.hero-card::before {
  content:''; position:absolute; top:-60px; right:-60px;
  width:200px; height:200px; border-radius:50%;
  background:rgba(0,192,122,.2); pointer-events:none;
}
.hc-label {
  font-family:var(--mono); font-size:11px;
  font-weight:500; letter-spacing:2px;
  text-transform:uppercase; color:rgba(255,255,255,.4);
  margin-bottom:14px;
}
.hc-price {
  font-family:var(--serif); font-size:72px;
  font-weight:400; color:#fff; line-height:1;
  margin-bottom:4px;
}
.hc-price sup { font-size:30px; vertical-align:super; }
.hc-price-sub {
  font-size:13px; color:rgba(255,255,255,.45);
  margin-bottom:28px; font-family:var(--mono);
}
.hc-feats { list-style:none; display:flex; flex-direction:column; gap:10px; margin-bottom:28px; }
.hc-feats li {
  display:flex; align-items:center; gap:10px;
  font-size:14px; color:rgba(255,255,255,.75);
}
.hc-feats li::before {
  content:''; width:18px; height:18px; border-radius:50%;
  background:rgba(0,192,122,.25); border:1px solid rgba(0,192,122,.4);
  flex-shrink:0; display:flex; align-items:center; justify-content:center;
  background-image:url("data:image/svg+xml,%3Csvg width='10' height='8' viewBox='0 0 10 8' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4l2.5 2.5L9 1' stroke='%2300c07a' stroke-width='1.5' fill='none' stroke-linecap='round'/%3E%3C/svg%3E");
  background-repeat:no-repeat; background-position:center;
}
.hc-cta {
  width:100%; padding:14px;
  background:var(--coral); color:#fff;
  border:none; border-radius:var(--r);
  font-size:15px; font-weight:700;
  font-family:var(--sans);
  transition:background .2s, transform .2s;
  box-shadow:0 4px 16px rgba(232,83,42,.35);
}
.hc-cta:hover { background:var(--coral2); transform:translateY(-1px); }
.hc-note {
  text-align:center; font-size:12px;
  color:rgba(255,255,255,.3); margin-top:10px;
  font-family:var(--mono);
}

/* ══════════════════════════════════════════════════════ TICKER */
.ticker {
  background:var(--forest); padding:14px 0;
  overflow:hidden; position:relative;
}
.ticker-track {
  display:flex; animation:roll 28s linear infinite;
  white-space:nowrap;
}
.t-item {
  display:inline-flex; align-items:center; gap:12px;
  font-family:var(--mono); font-size:11px;
  letter-spacing:2px; text-transform:uppercase;
  color:rgba(255,255,255,.4); padding:0 24px;
}
.t-sep { color:var(--sage); font-size:14px; }

/* ══════════════════════════════════════════════════════ STATS */
.stats { padding:72px 0; border-bottom:1px solid var(--line); }
.stats-grid {
  display:grid; grid-template-columns:repeat(4,1fr);
  gap:0; border:1px solid var(--line); border-radius:var(--rr); overflow:hidden;
}
.stat {
  padding:36px 28px;
  border-right:1px solid var(--line);
  transition:background .2s;
}
.stat:last-child { border-right:none; }
.stat:hover { background:var(--cream2); }
.stat-n {
  font-family:var(--mono); font-size:48px; font-weight:500;
  color:var(--forest); line-height:1; margin-bottom:8px;
  display:flex; align-items:baseline; gap:4px;
}
.stat-n .unit { font-size:22px; color:var(--coral); }
.stat-l { font-size:13px; color:var(--grey); line-height:1.4; }

/* ══════════════════════════════════════════════════════ HOW */
.how { padding:100px 0; }
.section-header { margin-bottom:56px; }
.section-header .eyebrow { margin-bottom:14px; }
.section-header h2 {
  font-family:var(--serif);
  font-size:clamp(34px,4vw,54px);
  font-weight:400; color:var(--ink);
  line-height:1.05; margin-bottom:16px;
}
.section-header h2 em { font-style:italic; color:var(--forest2); }
.section-header p { font-size:16px; color:var(--grey); line-height:1.7; max-width:480px; }

.steps-row {
  display:grid; grid-template-columns:repeat(4,1fr);
  gap:1px; background:var(--line);
  border:1px solid var(--line); border-radius:var(--rr); overflow:hidden;
}
.step {
  background:var(--cream); padding:36px 28px;
  transition:background .2s;
  position:relative;
}
.step:hover { background:var(--cream2); }
.step-num {
  font-family:var(--serif); font-size:52px; font-weight:300;
  color:var(--cream3); line-height:1; margin-bottom:20px;
  transition:color .2s;
}
.step:hover .step-num { color:var(--coral); }
.step-t {
  font-family:var(--serif); font-size:18px;
  color:var(--ink); margin-bottom:10px; font-weight:400;
}
.step-d { font-size:13px; color:var(--grey); line-height:1.6; }

/* ══════════════════════════════════════════════════════ PRICING */
.pricing {
  padding:100px 0;
  background:var(--forest);
  position:relative; overflow:hidden;
}
.pricing::before {
  content:''; position:absolute; bottom:-150px; right:-100px;
  width:500px; height:500px; border-radius:50%;
  background:radial-gradient(circle, rgba(0,192,122,.15) 0%, transparent 60%);
  pointer-events:none;
}
/* Eyebrow sobre verde profundo */
.pricing .eyebrow { color:rgba(255,255,255,.4); }
.pricing .eyebrow::before { background:rgba(255,255,255,.3); }
.pricing h2 { color:#fff; }
.pricing h2 em { color:rgba(0,192,122,.9); }
.pricing .section-header p { color:rgba(255,255,255,.5); }

.plans-grid {
  display:grid; grid-template-columns:repeat(3,1fr);
  gap:16px; margin-top:52px;
}
.plan {
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.08);
  border-radius:var(--rr); padding:36px 30px;
  transition:background .25s, transform .25s;
  position:relative;
}
.plan:hover { background:rgba(255,255,255,.07); transform:translateY(-4px); }

/* Plan destacado */
.plan.hi {
  background:var(--cream); border-color:var(--cream);
}
.plan.hi:hover { background:#fff; }
.plan.hi::before {
  content:'Más popular';
  position:absolute; top:-12px; left:50%; transform:translateX(-50%);
  background:var(--coral); color:#fff;
  font-size:11px; font-weight:700; letter-spacing:1.5px;
  text-transform:uppercase; padding:4px 16px; border-radius:100px;
}
.plan-tier {
  font-family:var(--mono); font-size:11px; font-weight:500;
  letter-spacing:2px; text-transform:uppercase;
  color:rgba(255,255,255,.3); margin-bottom:22px;
}
.plan.hi .plan-tier { color:var(--grey); }
.plan-price {
  font-family:var(--serif); font-size:54px; font-weight:400;
  color:#fff; line-height:1; margin-bottom:4px;
  display:flex; align-items:flex-start; gap:4px;
}
.plan.hi .plan-price { color:var(--ink); }
.plan-price sup { font-size:22px; padding-top:10px; }
.plan-mo { font-size:13px; color:rgba(255,255,255,.3); margin-bottom:24px; font-family:var(--mono); }
.plan.hi .plan-mo { color:var(--grey2); }
.plan-sep { height:1px; background:rgba(255,255,255,.08); margin-bottom:22px; }
.plan.hi .plan-sep { background:var(--line); }
.plan-feats { list-style:none; display:flex; flex-direction:column; gap:11px; margin-bottom:30px; }
.plan-feats li { display:flex; align-items:flex-start; gap:9px; font-size:14px; color:rgba(255,255,255,.6); }
.plan.hi .plan-feats li { color:var(--ink2); }
.ck {
  width:17px; height:17px; border-radius:4px;
  background:rgba(0,192,122,.2); flex-shrink:0; margin-top:1px;
  display:flex; align-items:center; justify-content:center;
  font-size:10px; color:rgba(255,255,255,.6);
  background-image:url("data:image/svg+xml,%3Csvg width='10' height='8' viewBox='0 0 10 8' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4l2.5 2.5L9 1' stroke='%2300c07a' stroke-width='1.5' fill='none' stroke-linecap='round'/%3E%3C/svg%3E");
  background-repeat:no-repeat; background-position:center;
}
.plan.hi .ck {
  background-color:rgba(0,192,122,.15);
  background-image:url("data:image/svg+xml,%3Csvg width='10' height='8' viewBox='0 0 10 8' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4l2.5 2.5L9 1' stroke='%230e6644' stroke-width='1.5' fill='none' stroke-linecap='round'/%3E%3C/svg%3E");
}
.plan-btn {
  width:100%; padding:12px;
  border-radius:var(--r); font-size:14px; font-weight:600;
  font-family:var(--sans);
  border:1.5px solid rgba(255,255,255,.12);
  background:transparent; color:rgba(255,255,255,.6);
  transition:all .2s;
}
.plan-btn:hover { background:rgba(255,255,255,.1); color:#fff; border-color:rgba(255,255,255,.25); }
.plan.hi .plan-btn {
  background:var(--coral); border-color:var(--coral); color:#fff;
  box-shadow:0 4px 16px rgba(232,83,42,.3);
}
.plan.hi .plan-btn:hover { background:var(--coral2); }

/* ══════════════════════════════════════════════════════ WHY */
.why { padding:100px 0; }
.why-layout { display:grid; grid-template-columns:1fr 1.3fr; gap:80px; align-items:start; }
.why-sticky { position:sticky; top:120px; }
.why-big {
  font-family:var(--serif); font-size:160px; font-weight:300;
  line-height:1; color:var(--cream3); margin-top:32px;
  letter-spacing:-4px; pointer-events:none;
}
.why-rows { display:flex; flex-direction:column; }
.wrow { border-top:1px solid var(--line); padding:24px 0; transition:padding .2s; }
.wrow:last-child { border-bottom:1px solid var(--line); }
.wrow:hover { padding-left:8px; }
.wrow-h { display:flex; align-items:center; gap:14px; margin-bottom:8px; }
.wnum { font-family:var(--mono); font-size:12px; color:var(--coral); min-width:28px; }
.wtit { font-family:var(--serif); font-size:19px; color:var(--ink); font-weight:400; }
.wdes { font-size:14px; color:var(--grey); line-height:1.7; padding-left:42px; }

/* ══════════════════════════════════════════════════════ CREATIVES */
.creatives {
  margin:0 40px; border-radius:var(--rrr);
  background:var(--cream2);
  border:1px solid var(--line);
  padding:72px 60px; position:relative; overflow:hidden;
}
.creatives::after {
  content:'★'; position:absolute; right:-20px; bottom:-40px;
  font-size:220px; color:var(--cream3); pointer-events:none; line-height:1;
}
.creatives-layout { display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center; }
.c-tags { display:flex; flex-wrap:wrap; gap:8px; margin-top:22px; }
.ctag {
  background:#fff; border:1px solid var(--line);
  color:var(--ink2); font-size:13px; font-weight:500;
  padding:6px 14px; border-radius:100px;
  transition:all .2s;
}
.ctag:hover { border-color:var(--sage); color:var(--forest2); }
.creatives p { font-size:15px; color:var(--grey); line-height:1.75; margin-bottom:14px; }

/* ══════════════════════════════════════════════════════ FAQ */
.faq { padding:100px 0; }
.faq-layout { display:grid; grid-template-columns:1fr 1.6fr; gap:80px; align-items:start; }
.faq-sticky { position:sticky; top:120px; }
.faq-rows { display:flex; flex-direction:column; }
.frow { border-top:1px solid var(--line); overflow:hidden; }
.frow:last-child { border-bottom:1px solid var(--line); }
.fq {
  width:100%; background:none; border:none; text-align:left;
  padding:18px 0; font-family:var(--serif); font-size:18px;
  color:var(--ink); cursor:pointer;
  display:flex; justify-content:space-between; align-items:center; gap:12px;
  transition:color .2s;
}
.fq:hover { color:var(--coral); }
.fq-ico {
  width:24px; height:24px; border-radius:50%;
  background:var(--cream2); flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
  font-size:16px; color:var(--grey);
  transition:transform .3s, background .2s;
}
.frow.open .fq-ico { transform:rotate(45deg); background:var(--coral-lo); color:var(--coral); }
.fa {
  max-height:0; overflow:hidden;
  transition:max-height .35s ease, padding .35s ease;
  font-size:14px; color:var(--grey); line-height:1.8;
}
.frow.open .fa { max-height:280px; padding-bottom:20px; }

/* ══════════════════════════════════════════════════════ CONTACT */
.contact { padding:100px 0 0; }
.contact-inner {
  background:var(--forest);
  border-radius:var(--rrr) var(--rrr) 0 0;
  padding:72px 72px 80px;
  position:relative; overflow:hidden;
}
.contact-inner::before {
  content:''; position:absolute; top:-100px; right:-100px;
  width:500px; height:500px; border-radius:50%;
  background:radial-gradient(circle, rgba(232,83,42,.12) 0%, transparent 65%);
  pointer-events:none;
}
.contact-inner::after {
  content:''; position:absolute; bottom:-100px; left:60px;
  width:400px; height:400px; border-radius:50%;
  background:radial-gradient(circle, rgba(0,192,122,.08) 0%, transparent 65%);
  pointer-events:none;
}
.contact-layout { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:start; }

/* Left sobre verde oscuro */
.contact-inner .eyebrow { color:rgba(255,255,255,.35); }
.contact-inner .eyebrow::before { background:rgba(255,255,255,.25); }
.cnt-h {
  font-family:var(--serif); font-size:clamp(36px,4vw,54px);
  color:#fff; font-weight:400; line-height:1.05; margin-bottom:18px;
}
.cnt-h em { font-style:italic; color:rgba(0,192,122,.8); }
.cnt-p { font-size:16px; color:rgba(255,255,255,.5); line-height:1.7; margin-bottom:32px; }
.cnt-feat { display:flex; align-items:flex-start; gap:14px; margin-bottom:18px; }
.cnt-ico {
  width:36px; height:36px; border-radius:8px;
  background:rgba(255,255,255,.06); flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
  font-size:16px;
}
.cnt-txt strong { display:block; font-size:14px; color:rgba(255,255,255,.8); font-weight:600; margin-bottom:2px; }
.cnt-txt span { font-size:13px; color:rgba(255,255,255,.35); }

/* Form */
.form-box {
  background:var(--cream);
  border-radius:var(--rr); padding:36px;
  position:relative; z-index:1;
}
.form-title {
  font-family:var(--serif); font-size:22px;
  color:var(--ink); margin-bottom:22px;
}
.f2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.fg { margin-bottom:14px; }
.fl { display:block; font-size:12px; font-weight:600; letter-spacing:.5px; color:var(--grey); margin-bottom:6px; }
.fi, .fsel, .fta {
  width:100%; padding:11px 14px;
  background:var(--cream); border:1.5px solid var(--line);
  border-radius:var(--r); font-family:var(--sans);
  font-size:14px; color:var(--ink); outline:none;
  transition:border-color .2s, box-shadow .2s;
}
.fi::placeholder, .fta::placeholder { color:var(--grey2); }
.fi:focus, .fsel:focus, .fta:focus {
  border-color:var(--coral);
  box-shadow:0 0 0 3px rgba(232,83,42,.08);
  background:#fff;
}
.fta { resize:vertical; min-height:88px; }
.fsel { appearance:none; cursor:pointer; background:#fff; }
.fsub {
  width:100%; padding:14px;
  background:var(--coral); color:#fff;
  border:none; border-radius:var(--r);
  font-size:15px; font-weight:700; font-family:var(--sans);
  transition:background .2s, transform .2s;
  box-shadow:0 4px 16px rgba(232,83,42,.25); margin-top:4px;
}
.fsub:hover { background:var(--coral2); transform:translateY(-1px); }
.fnote { text-align:center; font-size:12px; color:var(--grey2); margin-top:10px; }

/* ══════════════════════════════════════════════════════ FOOTER */
footer {
  background:var(--forest);
  padding:48px 0 32px;
  border-top:1px solid rgba(255,255,255,.06);
}
.foot-grid { display:grid; grid-template-columns:1.5fr 1fr 1fr 1fr; gap:48px; margin-bottom:48px; }
.flogo { display:flex; align-items:center; gap:4px; margin-bottom:14px; }
.flogo-w { font-family:var(--serif); font-size:20px; color:#fff; }
.flogo-d { width:6px; height:6px; background:var(--sage); border-radius:50%; margin-top:-10px; }
.ftag { font-size:13px; color:rgba(255,255,255,.35); line-height:1.6; max-width:200px; }
.fh { font-family:var(--mono); font-size:10px; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,.25); margin-bottom:14px; }
.fli { list-style:none; display:flex; flex-direction:column; gap:10px; }
.fli a { font-size:14px; color:rgba(255,255,255,.45); transition:color .2s; }
.fli a:hover { color:rgba(255,255,255,.8); }
.fbot { padding-top:24px; border-top:1px solid rgba(255,255,255,.06); display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; }
.fcp { font-size:13px; color:rgba(255,255,255,.25); font-family:var(--mono); }
.fleg { display:flex; gap:24px; }
.fleg a { font-size:13px; color:rgba(255,255,255,.25); transition:color .2s; }
.fleg a:hover { color:rgba(255,255,255,.5); }

